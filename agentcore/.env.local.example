# Public example only. Copy to agentcore/.env.local locally; do not commit real values.
LOCAL_DEV=1
ENABLE_BEDROCK=false
ENABLE_LIVE_MODEL=false
RUNTIME_DATA_MODE=fixture_first
AWS_REGION=eu-west-2
RAMS_LLM_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Cloud workflow deployment values. Keep real ARNs in untracked env only.
RAMS_SUPERVISOR_RUNTIME_ARN=
RAMS_SUBAGENT_EXECUTION_MODE=agentcore_harness
RAMS_HARNESS_ARNS=
RAMS_HARNESS_MODEL_PROVIDER=lite_llm
RAMS_HARNESS_MODEL_ID=gpt-5.4-mini
RAMS_HARNESS_API_BASE=
RAMS_HARNESS_API_KEY_CREDENTIAL_NAME=openai-gateway
RAMS_REPORT_STORE_TABLE=
