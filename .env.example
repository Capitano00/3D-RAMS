# Backend / no-AWS defaults
APP_ENV=local
ENABLE_BEDROCK=false
ENABLE_LIVE_MODEL=false
AWS_PROFILE=
AWS_REGION=eu-west-2

# Frontend
# Cloud mode: browser calls this signed proxy, which invokes the cloud entry runtime.
VITE_CLOUD_ENTRY_PROXY_URL=
# Explicit local-only mode for no-AWS development. Leave false for cloud workflow demos.
VITE_USE_LOCAL_ASIONE=false
# Local supervisor runtime path used only when VITE_USE_LOCAL_ASIONE=true.
VITE_AGENTCORE_URL=/agentcore/invocations
VITE_AGENTCORE_PROXY_TARGET=http://127.0.0.1:8080
VITE_CESIUM_ION_TOKEN=

# ASI / AgentCore entry runtime.
# Keep real API keys, runtime ARNs, bearer tokens, and signed URLs in hosted
# secrets or local untracked env files only. Do not commit real secrets here.
#
# OpenAI-compatible gateway path:
# - set ENTRY_AGENT_PROVIDER=openai for the Strands entry agent;
# - set ENTRY_INTAKE_PROVIDER=openai for LLM-first intake;
# - OPENAI_BASE_URL + OPENAI_API_KEY also select the OpenAI-compatible path
#   when providers are left blank.
ENTRY_AGENT_PROVIDER=openai
ENTRY_INTAKE_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Entry intake controls. Deterministic fallback preserves no-AWS Demo1 behavior.
ENTRY_INTAKE_MODE=llm_first
ENTRY_INTAKE_MODEL_ID=
ENTRY_INTAKE_FALLBACK=deterministic
ENTRY_INTAKE_MAX_RETRIES=1
ENTRY_INTAKE_TIMEOUT_SECONDS=20
ENTRY_INTAKE_MAX_TOKENS=1800

# Optional model settings. Keep credentials in hosted secrets or local .env only.
ENTRY_AGENT_MODEL_ID=gpt-5.4-mini
RAMS_LLM_PROVIDER=openai
RAMS_OPENAI_MODEL=gpt-5.4-mini

# Explicit legacy Bedrock settings. Use only when deliberately testing Bedrock;
# AgentCore service/package names may still contain bedrock-agentcore.
BEDROCK_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0
BEDROCK_MAX_TOKENS=1200
BEDROCK_TEMPERATURE=0.2
MATERIAL_EXTRACTION_MODEL_ID=amazon.nova-lite-v1:0
MATERIAL_EXTRACTION_MAX_TOKENS=900

# Test-only switches. Do not enable in normal demo runs.
BEDROCK_MOCK_RESPONSE=false
BEDROCK_SIMULATE_FAILURE=false

# Optional hosted AgentCore wiring. Leave ARNs empty unless deployed.
AGENTCORE_RUNTIME_ARN=
RAMS_SUPERVISOR_RUNTIME_ARN=
RAMS_SUBAGENT_EXECUTION_MODE=direct
RAMS_HARNESS_ARNS=
# Optional AgentCore Harness model override for deployed hackathon demos.
# Use lite_llm for OpenAI-compatible gateways with a custom base URL.
RAMS_HARNESS_MODEL_PROVIDER=
RAMS_HARNESS_MODEL_ID=
RAMS_HARNESS_API_BASE=
RAMS_HARNESS_API_KEY_ARN=
RAMS_HARNESS_API_KEY_CREDENTIAL_NAME=

# Optional report persistence. Leave unset for no-AWS local demos.
RAMS_REPORT_STORE_TABLE=
RAMS_REPORT_STORE_TTL_DAYS=
RAMS_ENABLE_DEV_REPORT_LOOKUP=false
RAMS_REVIEW_MAX_REVISIONS=2

# Optional Tavily/open-web signals. Disabled unless ENABLE_TAVILY=true and a
# real key is supplied through hosted secrets or a local untracked env file.
ENABLE_TAVILY=false
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT_SECONDS=20
TAVILY_SEARCH_DEPTH=basic

# Optional ASI-owned material API retrieval. Bearer tokens are secrets.
RAMS_ASI_MATERIAL_API_BASE_URL=
RAMS_ASI_MATERIAL_API_BEARER_TOKEN=

# Optional entry-agent MCP tool access. Disabled unless live outbound use is intended.
ENTRY_AGENT_ENABLE_EXA_MCP=false
ENTRY_AGENT_MCP_ENDPOINT=https://mcp.exa.ai/mcp

# Optional hosted smoke target. Public signed proxy URL only; do not put secrets here.
RAMS_HOSTED_ENTRY_URL=
RAMS_HOSTED_SMOKE_TIMEOUT=120
